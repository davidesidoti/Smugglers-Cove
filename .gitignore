# =============================================================
#  Unreal Engine — .gitignore
#  NOTE: the .uproject lives in SmugglersCove/, one level below
#  this repo root, so all UE rules are written depth-agnostic
#  (no leading slash, trailing slash on dirs) to match at any depth.
# =============================================================

# --- UE generated directories (any depth) ---
Binaries/
DerivedDataCache/
Intermediate/
Saved/
Build/
.vs/
.vsconfig
.idea/
.vscode/

# Keep PakBlacklist files inside Build/
!Build/*/
!Build/*/PakBlacklist*.txt
!Build/**/*.ico

# --- Generated project files ---
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# --- Compiled binaries / intermediates ---
*.slo
*.lo
*.o
*.obj
*.gch
*.pch
*.so
*.dylib
*.dll
*.lib
*.a
*.la
*.lai
*.exp
*.ilk
*.pdb
*.exe
*.out
*.app
*.ipa
*.mod

# --- Built map data (regenerated by the editor) ---
*_BuiltData.uasset

# --- Source art that should not be committed ---
SourceArt/**/*.png
SourceArt/**/*.tga

# =============================================================
#  Third-party editor TOOLING plugins (re-clonable, not shipped)
#  Kept out of the repo by decision: heavy (node_modules, DLLs)
#  and carry their own .git. Re-install per CLAUDE.md if needed.
# =============================================================
SmugglersCove/Plugins/UnrealClaude/
SmugglersCove/Plugins/VibeUE/

# --- Claude Code local-only settings (machine specific) ---
.claude/settings.local.json
